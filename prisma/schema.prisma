// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  SUPERADMIN
  ADMIN
  VET
  GROOMER
  RECEPTIONIST
  PHARMACIST
  STAFF
  USER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============================================================================
// MODELS
// ============================================================================

/// Clinic model - represents a veterinary clinic
model Clinic {
  id                String    @id @default(cuid())
  clinicName        String    @db.VarChar(255)
  clinicCode        String    @unique @db.VarChar(50)
  email             String    @unique @db.VarChar(255)
  phoneNumber       String?   @db.VarChar(20)
  address           String?   @db.Text
  city              String?   @db.VarChar(100)
  state             String?   @db.VarChar(100)
  zipCode           String?   @db.VarChar(20)
  country           String?   @db.VarChar(100)
  licenseNumber     String?   @unique @db.VarChar(100)
  subscriptionPlan  SubscriptionPlan @default(STARTER)
  maxUsers          Int       @default(10)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  users             User[]
  userMemberships   UserClinic[]
  pets              Pet[]
  customers         Customer[]
  appointments      Appointment[]
  groomingRecords   GroomingRecord[]
  pharmacyRecords   PharmacyRecord[]
  pharmacyInventory PharmacyInventory[]
  events            Event[]
  labTests          LabTest[]
  storeItems        StoreItem[]
  supplies          Supply[]
  transactions      Transaction[]
  vetCases          VetCase[]
  pharmacyDeliveries PharmacyDelivery[]
  storeDispensingRecords StoreDispensing[]

  @@index([clinicCode])
  @@index([email])
  @@index([isActive])
  @@map("clinics")
}

/// User model - represents system users (admin, staff, etc.)
model User {
  id                String    @id @default(cuid())
  clinicId          String?   // Nullable for SUPERADMIN
  username          String    @unique @db.VarChar(100)
  email             String    @unique @db.VarChar(255)
  password          String    @db.Text // Hashed password
  firstName         String?   @db.VarChar(100)
  lastName          String?   @db.VarChar(100)
  phoneNumber       String?   @db.VarChar(20)
  role              UserRole  @default(STAFF)
  allowedPages      String[]  @default([])
  isActive          Boolean   @default(true)
  lastLogin         DateTime?
  refreshTokens     String[]  // Array of refresh tokens
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  clinicMemberships UserClinic[]
  permissions       UserPermission[]
  appointments      Appointment[]
  groomingRecords   GroomingRecord[]
  pharmacyRecords   PharmacyRecord[]
  vetCases          VetCase[]
  assignedPets      Pet[]     @relation("AssignedVetPets")
  pharmacyDeliveries PharmacyDelivery[] @relation("PharmacyDeliveries")
  storeDispensingRecords StoreDispensing[] @relation("StoreDispensingRecords")

  @@unique([clinicId, username]) // Username must be unique per clinic
  @@index([clinicId])
  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

/// UserClinic model - assigns one user to one or more clinics
model UserClinic {
  id                String    @id @default(cuid())
  userId            String
  clinicId          String
  role              UserRole
  isDefault         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([userId])
  @@index([clinicId])
  @@map("user_clinics")
}

/// Permission model - defines system permissions
model Permission {
  id                String    @id @default(cuid())
  name              String    @unique @db.VarChar(100)
  description       String?   @db.Text
  category          String?   @db.VarChar(50) // e.g., CUSTOMER, PET, APPOINTMENT, etc.
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  users             UserPermission[]

  @@index([category])
  @@map("permissions")
}

/// UserPermission model - junction table for many-to-many between User and Permission
model UserPermission {
  id                String    @id @default(cuid())
  userId            String
  permissionId      String
  createdAt         DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission        Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@map("user_permissions")
}

/// Customer model - represents pet owners
model Customer {
  id                String    @id @default(cuid())
  customerId        String    @unique @db.VarChar(50) // e.g., CUS-1001
  code              String?   @db.VarChar(20) // e.g., HA210 (first 2 letters of name + last 3 digits of phone)
  clinicId          String
  firstName         String    @db.VarChar(100)
  lastName          String    @db.VarChar(100)
  email             String?   @db.VarChar(255)
  phoneNumber       String?   @db.VarChar(20)
  address           String?   @db.Text
  city              String?   @db.VarChar(100)
  state             String?   @db.VarChar(100)
  zipCode           String?   @db.VarChar(20)
  country           String?   @db.VarChar(100)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pets              Pet[]
  appointments      Appointment[]
  pharmacyDeliveries PharmacyDelivery[]
  storeDispensingRecords StoreDispensing[]

  @@index([clinicId])
  @@index([email])
  @@index([phoneNumber])
  @@index([customerId])
  @@index([code])
  @@map("customers")
}

/// Pet model - represents pets owned by customers
model Pet {
  id                String    @id @default(cuid())
  petId             String    @unique @db.VarChar(50) // e.g., PET-1001
  clinicId          String
  customerId        String
  name              String    @db.VarChar(100)
  species           String    @db.VarChar(50) // e.g., Dog, Cat, Bird, etc.
  breed             String?   @db.VarChar(100)
  age               Int?      // Age in months
  gender            String?   @db.VarChar(20) // Male, Female, Unknown
  weight            Float?    // Weight in kg
  colour            String?   @db.VarChar(100) // Pet color/colour
  bloodGroup        String?   @db.VarChar(20) // Blood group (e.g., DEA 1.1+, DEA 1.1-, etc. for dogs; A, B, AB for cats)
  medicalNotes      String?   @db.Text
  microchipId       String?   @unique @db.VarChar(100)
  dateOfBirth       DateTime?
  assignedVetId     String?   // Currently assigned vet
  status            String?   @default("AVAILABLE") @db.VarChar(20)  // AVAILABLE, ADMITTED, DISCHARGED
  admissionDate    DateTime?
  dischargeDate    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  assignedVet      User?     @relation("AssignedVetPets", fields: [assignedVetId], references: [id], onDelete: SetNull)
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  owner             Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  groomingRecords   GroomingRecord[]
  pharmacyRecords   PharmacyRecord[]
  labTests          LabTest[]  @relation("LabTests")
  vetCases          VetCase[]
  pharmacyDeliveries PharmacyDelivery[]
  storeDispensingRecords StoreDispensing[]

  @@index([clinicId])
  @@index([customerId])
  @@index([species])
  @@index([petId])
  @@map("pets")
}

/// Appointment model - represents veterinary appointments
model Appointment {
  id                String    @id @default(cuid())
  clinicId          String
  petId             String
  customerId        String
  vetId             String
  appointmentDate   DateTime
  reason            String?   @db.Text
  status            AppointmentStatus @default(PENDING)
  notes             String?   @db.Text
  diagnosis         String?   @db.Text
  treatment         String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet               Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vet               User      @relation(fields: [vetId], references: [id], onDelete: Restrict)
  vetCases          VetCase[]

  @@index([clinicId])
  @@index([petId])
  @@index([customerId])
  @@index([vetId])
  @@index([appointmentDate])
  @@index([status])
  @@map("appointments")
}

/// GroomingRecord model - represents pet grooming services
model GroomingRecord {
  id                String    @id @default(cuid())
  clinicId          String
  petId             String
  groomerId         String
  services          String    @db.Text // JSON array of services
  notes             String?   @db.Text
  cost              Float?
  groomingDate      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet               Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  groomer           User      @relation(fields: [groomerId], references: [id], onDelete: Restrict)

  @@index([clinicId])
  @@index([petId])
  @@index([groomerId])
  @@index([groomingDate])
  @@map("grooming_records")
}

/// PharmacyRecord model - represents pharmacy/medication records
model PharmacyRecord {
  id                String    @id @default(cuid())
  clinicId          String
  petId             String
  pharmacistId      String
  medicineName      String    @db.VarChar(255)
  dosage            String    @db.VarChar(100)
  quantity          Int?
  duration          String?   @db.VarChar(100) // e.g., "10 days"
  notes             String?   @db.Text
  cost              Float?
  prescribedDate    DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet               Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  pharmacist        User      @relation(fields: [pharmacistId], references: [id], onDelete: Restrict)

  @@index([clinicId])
  @@index([petId])
  @@index([pharmacistId])
  @@index([prescribedDate])
  @@map("pharmacy_records")
}

/// PharmacyInventory model - represents medicine inventory stock
model PharmacyInventory {
  id                String    @id @default(cuid())
  clinicId          String
  productName       String    @db.VarChar(255)
  dosage            String?   @db.VarChar(100)
  power             String?   @db.VarChar(100)
  type              String    @db.VarChar(50)
  weight            String?   @db.VarChar(100)
  mfgDate           DateTime?
  expDate           DateTime?
  mrp               Float?    @default(0)
  discount          Float?    @default(0)
  vendor            String?   @db.VarChar(255)
  payable           Float?    @default(0)
  stock             Int?      @default(0)
  inwardDate        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pharmacyDeliveries PharmacyDelivery[]

  @@index([clinicId])
  @@index([productName])
  @@index([type])
  @@index([vendor])
  @@map("pharmacy_inventory")
}

/// Event model - represents clinic events and schedules
model Event {
  id                String    @id @default(cuid())
  clinicId          String
  title             String    @db.VarChar(255)
  description       String?   @db.Text
  type              String?   @db.VarChar(100) // e.g., Meeting, Holiday, Training, etc.
  date              DateTime
  time              String?   @db.VarChar(20) // e.g., "10:30 AM"
  location          String?   @db.VarChar(255)
  attendees         Int?      @default(0)
  status            String?   @db.VarChar(50) @default("Confirmed") // Confirmed, Pending, Cancelled
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([date])
  @@index([status])
  @@map("events")
}

/// LabTest model - represents laboratory tests
model LabTest {
  id                String    @id @default(cuid())
  clinicId          String
  petId             String?
  petName           String?   @db.VarChar(255)
  testType          String    @db.VarChar(255)
  date              DateTime  @default(now())
  result            String?   @db.Text
  status            String?   @db.VarChar(50) @default("Complete") // Complete, Pending, Progress
  veterinarian      String?   @db.VarChar(255)
  notes             String?   @db.Text
  reportUrl         String?   @db.Text // PDF report URL from Supabase
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet               Pet?      @relation("LabTests", fields: [petId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([petId])
  @@index([testType])
  @@index([status])
  @@map("lab_tests")
}

/// StoreItem model - represents pet store inventory
model StoreItem {
  id                String    @id @default(cuid())
  clinicId          String
  name              String    @db.VarChar(255)
  category          String?   @db.VarChar(100) // e.g., Food, Toys, Accessories, etc.
  description       String?   @db.Text
  price             Float?
  quantity          Int?      @default(0)
  supplier          String?   @db.VarChar(255)
  expiryDate        DateTime?
  inwardDate        DateTime?
  outwardDate       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  storeDispensingRecords StoreDispensing[]

  @@index([clinicId])
  @@index([category])
  @@index([name])
  @@map("store_items")
}

/// Supply model - represents clinic supplies inventory
model Supply {
  id                String    @id @default(cuid())
  clinicId          String
  name              String    @db.VarChar(255)
  category          String?   @db.VarChar(100) // e.g., Medical, Cleaning, Office, etc.
  description       String?   @db.Text
  quantity          Int?      @default(0)
  reorderLevel      Int?      @default(10)
  cost              Float?    @default(0) // Unit price/cost
  supplier          String?   @db.VarChar(255)
  expiryDate        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pharmacyDeliveries PharmacyDelivery[]

  @@index([clinicId])
  @@index([category])
  @@index([name])
  @@map("supplies")
}

/// Transaction model - represents financial transactions
model Transaction {
  id                String    @id @default(cuid())
  clinicId          String
  description       String    @db.Text
  type              String    @db.VarChar(50) // Income or Expense
  amount            Float
  date              DateTime  @default(now())
  paymentMethod     String?   @db.VarChar(100) // e.g., Cash, Card, Check, etc.
  category          String?   @db.VarChar(100) // e.g., Salary, Medicine, Equipment, etc.
  status            String?   @db.VarChar(50) @default("Completed") // Completed, Pending, Cancelled
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([type])
  @@index([date])
  @@index([status])
  @@map("transactions")
}

/// SuperAdminFund model - represents super admin fund and donation entries
model SuperAdminFund {
  id                String    @id @default(cuid())
  donorName         String    @db.VarChar(255)
  amount            Float
  date              DateTime  @default(now())
  paymentMode       String    @db.VarChar(100)
  receivedBy        String    @db.VarChar(255)
  proofUrl          String?   @db.Text
  proofFileName     String?   @db.VarChar(255)
  proofMimeType     String?   @db.VarChar(100)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([date])
  @@index([createdAt])
  @@map("superadmin_funds")
}

// ============================================================================
// VET SECTION MODELS
// ============================================================================

/// Case status enum
enum CaseStatus {
  ACTIVE
  CLOSED
  FOLLOW_UP
}

/// VetCase model - represents a medical case for a pet
model VetCase {
  id                String      @id @default(cuid())
  clinicId          String
  petId             String
  appointmentId     String?
  vetId             String
  caseNumber        String      @unique @db.VarChar(50) // e.g., CASE-001
  medicalRecordNumber String?   @unique @db.VarChar(50) // e.g., MR-2026-001 (unique medical record ID)
  status            CaseStatus  @default(ACTIVE)
  chiefComplaint    String?     @db.Text
  caseDate          DateTime    @default(now())
  closedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet               Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  appointment       Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  vet               User        @relation(fields: [vetId], references: [id], onDelete: Restrict)
  symptoms          SymptomRecord[]
  imaging           ImagingRecord[]
  procedures        ProcedureRecord[]
  vaccinations      VaccinationRecord[]
  diagnoses         CaseDiagnosis[]

  @@index([clinicId])
  @@index([petId])
  @@index([vetId])
  @@index([status])
  @@index([caseNumber])
  @@index([medicalRecordNumber])
  @@map("vet_cases")
}

/// SymptomRecord model - stores symptoms and vitals
model SymptomRecord {
  id                String    @id @default(cuid())
  vetCaseId         String
  chiefComplaint    String?   @db.Text
  symptomsObserved String?   @db.Text // JSON array of symptoms
  clinicalNotes    String?   @db.Text
  temperature       Float?    // Body temperature in Fahrenheit
  heartRate         Int?      // Beats per minute
  pulse             Int?      // Pulse rate in beats per minute
  weight            Float?    // Weight in kg
  appetiteStatus    String?   @db.VarChar(50) // Normal, Poor, Good, None
  diagnosticPlan    String?   @db.Text
  recordedAt        DateTime  @default(now())
  recordedBy        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  vetCase           VetCase   @relation(fields: [vetCaseId], references: [id], onDelete: Cascade)

  @@index([vetCaseId])
  @@index([recordedAt])
  @@map("symptom_records")
}

/// ImagingRecord model - stores imaging requests and results
enum ImagingType {
  XRAY
  ULTRASOUND
  MRI
  CT_SCAN
}

enum ImagingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ImagingRecord {
  id                String        @id @default(cuid())
  vetCaseId         String
  imagingType       ImagingType
  bodyPart          String?       @db.VarChar(255) // Name of the body part being imaged (e.g., "Left Front Leg", "Abdomen")
  instructions      String?       @db.Text
  findings          String?       @db.Text
  status            ImagingStatus @default(PENDING)
  reportUrl         String?       @db.Text
  imagingDate       DateTime      @default(now()) // Date of imaging
  scheduledDate     DateTime?
  completedDate     DateTime?
  cost              Float?
  notes             String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt          DateTime?

  // Relations
  vetCase           VetCase       @relation(fields: [vetCaseId], references: [id], onDelete: Cascade)

  @@index([vetCaseId])
  @@index([imagingType])
  @@index([status])
  @@map("imaging_records")
}

/// ProcedureRecord model - stores procedures performed
model ProcedureRecord {
  id                String    @id @default(cuid())
  vetCaseId         String
  parentProcedureId String?
  procedureName     String    @db.VarChar(255)
  description       String?   @db.Text
  cost              Float?
  procedureDate     DateTime  @default(now())
  notes             String?   @db.Text
  performedBy       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  vetCase           VetCase   @relation(fields: [vetCaseId], references: [id], onDelete: Cascade)
  parentProcedure   ProcedureRecord?  @relation("ProcedureFollowUps", fields: [parentProcedureId], references: [id], onDelete: SetNull)
  followUpProcedures ProcedureRecord[] @relation("ProcedureFollowUps")

  @@index([vetCaseId])
  @@index([parentProcedureId])
  @@index([procedureDate])
  @@map("procedure_records")
}

/// VaccinationRecord model - stores vaccination history
model VaccinationRecord {
  id                String    @id @default(cuid())
  vetCaseId         String
  vaccineName       String    @db.VarChar(255)
  dueDate           DateTime?
  administeredDate  DateTime?
  nextDueDate       DateTime?
  dose              String?   @db.VarChar(100)
  batchNumber       String?   @db.VarChar(100)
  administeredBy    String?
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  vetCase           VetCase   @relation(fields: [vetCaseId], references: [id], onDelete: Cascade)

  @@index([vetCaseId])
  @@index([vaccineName])
  @@map("vaccination_records")
}

/// CaseDiagnosis model - stores diagnosis and prescriptions
model CaseDiagnosis {
  id                String    @id @default(cuid())
  vetCaseId         String
  diagnosis         String    @db.Text
  treatmentPlan     String?   @db.Text
  dischargeNote     String?   @db.Text
  physicianNote     String?   @db.Text
  notes             String?   @db.Text
  followUpDate      DateTime?
  followUpTimeSlot  String?   @db.VarChar(10)
  remarks           String?   @db.Text
  diagnosedAt       DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  vetCase           VetCase   @relation(fields: [vetCaseId], references: [id], onDelete: Cascade)
  medications       Prescription[]

  @@index([vetCaseId])
  @@map("case_diagnoses")
}

/// Prescription model - stores medications prescribed
model Prescription {
  id                String    @id @default(cuid())
  caseDiagnosisId   String
  medicineName      String    @db.VarChar(255)
  dosage            String    @db.VarChar(100) // e.g., "10mg"
  frequency         String    @db.VarChar(100) // e.g., "Twice daily"
  duration          String    @db.VarChar(100) // e.g., "7 days"
  notes             String?   @db.Text
  cost              Float?
  prescribedAt      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  caseDiagnosis     CaseDiagnosis @relation(fields: [caseDiagnosisId], references: [id], onDelete: Cascade)
  pharmacyDeliveries PharmacyDelivery[]

  @@index([caseDiagnosisId])
  @@map("prescriptions")
}

// ============================================================================
// PHARMACY & STORE DELIVERY/DISPENSING MODELS
// ============================================================================

/// DispensingType enum - distinguishes between retail sale and clinic use
enum DispensingType {
  SALE              // Customer purchase from store
  CLINIC_USE        // Clinic internal use for treatment
}

/// PharmacyDelivery model - tracks medicines given to customers/pets
model PharmacyDelivery {
  id                String    @id @default(cuid())
  clinicId          String
  prescriptionId    String?   // Optional link to prescription
  supplyId          String?   // Optional link to supply/medicine
  pharmacyInventoryId String? // Optional link to pharmacy inventory stock
  medicineName      String    @db.VarChar(255)
  quantity          Int
  dosage            String?   @db.VarChar(100) // dosage info for reference
  petId             String?   // If given directly to pet (clinic use)
  customerId        String?   // If given to customer (customer purchase)
  deliveredBy       String    // User ID of staff who delivered
  deliveryDate      DateTime  @default(now())
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  prescription      Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  supply            Supply?   @relation(fields: [supplyId], references: [id], onDelete: SetNull)
  pharmacyInventory PharmacyInventory? @relation(fields: [pharmacyInventoryId], references: [id], onDelete: SetNull)
  pet               Pet?      @relation(fields: [petId], references: [id], onDelete: SetNull)
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staff             User      @relation("PharmacyDeliveries", fields: [deliveredBy], references: [id], onDelete: Restrict)

  @@index([clinicId])
  @@index([prescriptionId])
  @@index([supplyId])
  @@index([pharmacyInventoryId])
  @@index([petId])
  @@index([customerId])
  @@index([deliveredBy])
  @@index([deliveryDate])
  @@map("pharmacy_deliveries")
}

/// StoreDispensing model - tracks items sold or used internally
model StoreDispensing {
  id                String      @id @default(cuid())
  clinicId          String
  storeItemId       String
  quantity          Int
  dispensingType    DispensingType
  petId             String?     // If clinic use or given to specific pet
  customerId        String?     // If sale to customer
  dispensedBy       String      // User ID of staff who dispensed
  dispensingDate    DateTime    @default(now())
  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  // Relations
  clinic            Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  storeItem         StoreItem   @relation(fields: [storeItemId], references: [id], onDelete: Restrict)
  pet               Pet?        @relation(fields: [petId], references: [id], onDelete: SetNull)
  customer          Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staff             User        @relation("StoreDispensingRecords", fields: [dispensedBy], references: [id], onDelete: Restrict)

  @@index([clinicId])
  @@index([storeItemId])
  @@index([petId])
  @@index([customerId])
  @@index([dispensedBy])
  @@index([dispensingType])
  @@index([dispensingDate])
  @@map("store_dispensing")
}
